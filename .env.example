# Copy this file to ".env" and fill in your keys. .env is git-ignored.

# Required to fix low volume + enable Codex detection + pagination.
GITHUB_TOKEN=

# Optional: enables AI one-line summaries. Without it, the repo's own
# description is used instead. Get a free key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional: override the free summary model.
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
